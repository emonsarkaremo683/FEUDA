{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "types": ["node"],
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowJs": true,
    "noEmit": true
  },
  "include": ["**/*.ts"]
}
